# ─────────────────────────────────────────────────────────────
# Google OAuth2 Credentials
# ─────────────────────────────────────────────────────────────

# Path to the OAuth2 client credentials JSON downloaded from
# Google Cloud Console → APIs & Services → Credentials
GOOGLE_CREDENTIALS_PATH=credentials.json

# Path where the access/refresh token will be stored after
# the first OAuth2 browser login flow
GOOGLE_TOKEN_PATH=token.json

# ─────────────────────────────────────────────────────────────
# Server Transport (optional)
# ─────────────────────────────────────────────────────────────

# Set to "sse" to run as an HTTP SSE server instead of stdio
# MCP_TRANSPORT=stdio

# Port for SSE transport (default: 8000)
# MCP_SSE_PORT=8000

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
